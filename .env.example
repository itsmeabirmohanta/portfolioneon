# Neon Postgres connection string
DATABASE_URL='postgresql://user:password@host/dbname?sslmode=require'

# Local development only: Express API server URL (not needed in production)
VITE_API_BASE_URL="http://localhost:8787"

# Express API port for local and container deployment
API_PORT="8787"

# Optional comma-separated allowlist for browser origins
# Example: CORS_ALLOWLIST="https://your-domain.com,https://www.your-domain.com"
CORS_ALLOWLIST=""

# Protects /api/seed endpoint (required in production for server deployment)
SEED_API_KEY="replace-with-a-long-random-secret"
